<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF8F0">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Cat Header -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="12dp"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/catMoodEmoji"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="😺"
                    android:textSize="40sp"
                    android:layout_marginEnd="12dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/catNameText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Imbir"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="#4A2F1B" />

                    <TextView
                        android:id="@+id/catLevelText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Lvl 1 · XP 0"
                        android:textSize="14sp"
                        android:textColor="#888888" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="end">

                    <TextView
                        android:id="@+id/stageText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🐱 Kitten"
                        android:textSize="14sp"
                        android:textColor="#E8863A"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/personalityText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✨ Neutral"
                        android:textSize="13sp"
                        android:textColor="#666666" />

                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Cat Sprite Area -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:layout_marginBottom="8dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="#FDF5E6">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <ImageView
                    android:id="@+id/catSprite"
                    android:layout_width="200dp"
                    android:layout_height="200dp"
                    android:layout_gravity="center"
                    android:src="@drawable/cat_idle"
                    android:contentDescription="cat sprite"
                    android:scaleType="fitCenter" />

                <ImageView
                    android:id="@+id/catSpriteB"
                    android:layout_width="200dp"
                    android:layout_height="200dp"
                    android:layout_gravity="center"
                    android:contentDescription="cat sprite layer B"
                    android:scaleType="fitCenter"
                    android:visibility="invisible" />

            </FrameLayout>
        </androidx.cardview.widget.CardView>

        <!-- Event Banner -->
        <androidx.cardview.widget.CardView
            android:id="@+id/eventCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:visibility="gone"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#FFF3CD">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:id="@+id/eventTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#856404" />

                <TextView
                    android:id="@+id/eventDesc"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:textColor="#856404" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Stats Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Stats"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#4A2F1B"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/hungerLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🍗 Hunger 80%"
                    android:textSize="13sp"
                    android:textColor="#555555" />
                <ProgressBar
                    android:id="@+id/hungerBar"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="10dp"
                    android:max="100"
                    android:progress="80"
                    android:progressTint="#4CAF50"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:id="@+id/happinessLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="😺 Happiness 100%"
                    android:textSize="13sp"
                    android:textColor="#555555" />
                <ProgressBar
                    android:id="@+id/happinessBar"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="10dp"
                    android:max="100"
                    android:progress="100"
                    android:progressTint="#FF9800"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:id="@+id/energyLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚡ Energy 100%"
                    android:textSize="13sp"
                    android:textColor="#555555" />
                <ProgressBar
                    android:id="@+id/energyBar"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="10dp"
                    android:max="100"
                    android:progress="100"
                    android:progressTint="#2196F3"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:id="@+id/cleanLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🛁 Clean 100%"
                    android:textSize="13sp"
                    android:textColor="#555555" />
                <ProgressBar
                    android:id="@+id/cleanBar"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="10dp"
                    android:max="100"
                    android:progress="100"
                    android:progressTint="#00BCD4"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:id="@+id/healthLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="❤️ Health 100%"
                    android:textSize="13sp"
                    android:textColor="#555555" />
                <ProgressBar
                    android:id="@+id/healthBar"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="10dp"
                    android:max="100"
                    android:progress="100"
                    android:progressTint="#F44336"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:id="@+id/trustLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💛 Trust 10%"
                    android:textSize="13sp"
                    android:textColor="#555555" />
                <ProgressBar
                    android:id="@+id/trustBar"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="10dp"
                    android:max="100"
                    android:progress="10"
                    android:progressTint="#FFC107"
                    android:layout_marginBottom="2dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Actions Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Care"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#4A2F1B"
                    android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btnFeed"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="4dp"
                        android:text="🍗 Feed"
                        android:backgroundTint="#E8863A"
                        android:textColor="#FFFFFF"
                        style="@style/Widget.Material3.Button" />

                    <Button
                        android:id="@+id/btnPet"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="4dp"
                        android:text="✋ Pet"
                        android:backgroundTint="#FF9800"
                        android:textColor="#FFFFFF"
                        style="@style/Widget.Material3.Button" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp">

                    <Button
                        android:id="@+id/btnPlay"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="4dp"
                        android:text="🎾 Play"
                        android:backgroundTint="#4CAF50"
                        android:textColor="#FFFFFF"
                        style="@style/Widget.Material3.Button" />

                    <Button
                        android:id="@+id/btnSleep"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="4dp"
                        android:text="😴 Sleep"
                        android:backgroundTint="#5C6BC0"
                        android:textColor="#FFFFFF"
                        style="@style/Widget.Material3.Button" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp">

                    <Button
                        android:id="@+id/btnWash"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="4dp"
                        android:text="🛁 Wash"
                        android:backgroundTint="#00BCD4"
                        android:textColor="#FFFFFF"
                        style="@style/Widget.Material3.Button" />

                    <Button
                        android:id="@+id/btnTrick"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="4dp"
                        android:text="🎩 Teach"
                        android:backgroundTint="#9C27B0"
                        android:textColor="#FFFFFF"
                        style="@style/Widget.Material3.Button" />

                </LinearLayout>

                <Button
                    android:id="@+id/btnMedicine"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="💊 Give Medicine"
                    android:backgroundTint="#F44336"
                    android:textColor="#FFFFFF"
                    android:visibility="gone"
                    style="@style/Widget.Material3.Button" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Mini-games Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mini-games"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#4A2F1B"
                    android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btnLaser"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="4dp"
                        android:text="🔴 Laser Chase"
                        android:backgroundTint="#FF5722"
                        android:textColor="#FFFFFF"
                        style="@style/Widget.Material3.Button" />

                    <Button
                        android:id="@+id/btnMouse"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="4dp"
                        android:text="🐭 Mouse Hunt"
                        android:backgroundTint="#795548"
                        android:textColor="#FFFFFF"
                        style="@style/Widget.Material3.Button" />

                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>