<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFF8F0">

    <!-- Room Preview -->
    <LinearLayout
        android:id="@+id/roomPreview"
        android:layout_width="match_parent"
        android:layout_height="160dp"
        android:orientation="vertical"
        android:gravity="center"
        android:background="#FDF5E6">

        <TextView
            android:id="@+id/roomEmojiRow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🐱"
            android:textSize="36sp" />

        <TextView
            android:id="@+id/roomBonusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Room bonuses: +0 😺 mood  +0 ⚡ energy"
            android:textSize="13sp"
            android:textColor="#555555"
            android:layout_marginTop="8dp" />

    </LinearLayout>

    <!-- Filter Tabs -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="8dp">

            <TextView
                android:id="@+id/filterAll"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="All"
                android:padding="8dp"
                android:textColor="#E8863A"
                android:textStyle="bold"
                android:background="@drawable/bg_room"
                android:layout_marginEnd="4dp" />

            <TextView
                android:id="@+id/filterWallpaper"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⬜ Wallpaper"
                android:padding="8dp"
                android:textColor="#555555"
                android:layout_marginEnd="4dp" />

            <TextView
                android:id="@+id/filterFurniture"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🛋️ Furniture"
                android:padding="8dp"
                android:textColor="#555555"
                android:layout_marginEnd="4dp" />

            <TextView
                android:id="@+id/filterToy"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🧶 Toys"
                android:padding="8dp"
                android:textColor="#555555"
                android:layout_marginEnd="4dp" />

            <TextView
                android:id="@+id/filterDecoration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🌱 Decor"
                android:padding="8dp"
                android:textColor="#555555" />

        </LinearLayout>
    </HorizontalScrollView>

    <!-- Items List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/roomItemsRecycler"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp"
        android:clipToPadding="false" />

</LinearLayout>