<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- ФОН СЦЕНЫ -->
    <ImageView
        android:id="@+id/bgImage"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/bg_room" />

    <!-- ОСНОВНОЙ UI -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- TITLE -->
        <TextView
            android:id="@+id/title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Имбирь"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#4A2F1B"
            android:layout_gravity="center"
            android:paddingBottom="10dp" />

        <!-- CAT -->
        <ImageView
            android:id="@+id/catSprite"
            android:layout_width="240dp"
            android:layout_height="240dp"
            android:layout_gravity="center"
            android:src="@drawable/cat_idle"
            android:contentDescription="cat" />

        <!-- STATS CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp"
            android:background="#DDFFFFFF">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hunger"
                android:textColor="#000000" />
            <ProgressBar
                android:id="@+id/hungerBar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="14dp"
                android:max="100"
                android:progress="100"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mood"
                android:textColor="#000000" />
            <ProgressBar
                android:id="@+id/moodBar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="14dp"
                android:max="100"
                android:progress="100"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Energy"
                android:textColor="#000000" />
            <ProgressBar
                android:id="@+id/energyBar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="14dp"
                android:max="100"
                android:progress="100"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cleanliness"
                android:textColor="#000000" />
            <ProgressBar
                android:id="@+id/cleanBar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="14dp"
                android:max="100"
                android:progress="100"/>

        </LinearLayout>

        <!-- BUTTONS -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="12dp">

            <Button
                android:id="@+id/btnFeed"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🍗 Feed"/>

            <Button
                android:id="@+id/btnPlay"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🎾 Play"/>

            <Button
                android:id="@+id/btnSleep"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="😴 Sleep"/>

            <Button
                android:id="@+id/btnWash"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🛁 Wash"/>

        </LinearLayout>

    </LinearLayout>

</FrameLayout>